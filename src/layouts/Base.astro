---
import "@/styles/global.css";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { SITE } from "@/data/site";

interface Props {
  title?: string;
  description?: string;
  /** Article metadata for og:type=article pages */
  article?: {
    publishedAt: Date;
    updatedAt?: Date;
    tags?: readonly string[];
  };
  jsonLd?: Record<string, unknown>;
}

const { title, description = SITE.description, article, jsonLd } = Astro.props;

const pageTitle = title ? `${title} — ${SITE.name}` : `${SITE.name} — Software Engineer`;
const canonical = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang={SITE.locale} data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content={SITE.name} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon-32.png" type="image/png" sizes="32x32" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={`${SITE.name} — Blog`}
      href={new URL("/rss.xml", Astro.site)}
    />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph -->
    <meta property="og:type" content={article ? "article" : "website"} />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="en_US" />
    {
      article && (
        <>
          <meta
            property="article:published_time"
            content={article.publishedAt.toISOString()}
          />
          {article.updatedAt && (
            <meta
              property="article:modified_time"
              content={article.updatedAt.toISOString()}
            />
          )}
          {(article.tags ?? []).map((tag) => (
            <meta property="article:tag" content={tag} />
          ))}
        </>
      )
    }

    <!-- Twitter -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:site" content="@SooditK" />
    <meta name="twitter:creator" content="@SooditK" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />

    {
      jsonLd && (
        <script
          is:inline
          type="application/ld+json"
          set:html={JSON.stringify(jsonLd)}
        />
      )
    }

    <!-- Theme init: the only render-blocking script on the site (~300 bytes).
         Runs before paint to avoid a flash of the wrong theme. -->
    <script is:inline>
      (() => {
        let theme;
        try {
          theme = localStorage.getItem("theme");
        } catch {}
        if (theme !== "light" && theme !== "dark") {
          theme = matchMedia("(prefers-color-scheme: dark)").matches
            ? "dark"
            : "light";
        }
        document.documentElement.dataset.theme = theme;
      })();
    </script>
  </head>
  <body class="mx-auto flex min-h-dvh w-full max-w-2xl flex-col px-6">
    <Header />
    <main class="flex-1 py-10">
      <slot />
    </main>
    <Footer />
  </body>
</html>
