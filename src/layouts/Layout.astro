---
import BaseHead, {
  Props as BaseHeadProps,
} from "src/components/BaseHead.astro";
import { ViewTransitions } from "astro:transitions";

type Props = {
  head: BaseHeadProps;
  class?: string;
};
const { head, class: className } = Astro.props;
---

<!doctype html>
<html lang="en-us">
  <head>
    <BaseHead {...head}>
      <slot name="pre-head" slot="pre-head" />
      <slot name="head" />
    </BaseHead>
    <ViewTransitions />
  </head>
  <body>
    <main class={className}>
      <slot />
    </main>
  </body>
</html>
