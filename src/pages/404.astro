---
import Base from "@/layouts/Base.astro";
---

<Base title="Not found" description="This page does not exist.">
  <section class="py-16 text-center">
    <p class="text-sm font-medium uppercase tracking-widest text-faint">404</p>
    <h1 class="mt-2 text-2xl font-semibold tracking-tight">Page not found</h1>
    <p class="mt-3 text-muted">
      The page you're looking for doesn't exist or has moved.
    </p>
    <a
      href="/"
      class="mt-6 inline-block text-sm text-muted underline decoration-line underline-offset-4 transition-colors hover:text-foreground"
    >
      Back home
    </a>
  </section>
</Base>
