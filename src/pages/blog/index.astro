---
import { getCollection } from "astro:content";
import Base from "@/layouts/Base.astro";
import PostList from "@/components/PostList.astro";
import { SITE } from "@/data/site";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf(),
);
---

<Base
  title="Blog"
  description={`Writing on software engineering and AI by ${SITE.name}.`}
>
  <h1 class="text-2xl font-semibold tracking-tight">Blog</h1>
  <p class="mt-1 text-muted">Writing on software engineering and AI.</p>
  <div class="mt-8">
    {
      posts.length > 0 ? (
        <PostList posts={posts} />
      ) : (
        <p class="text-muted">Nothing here yet.</p>
      )
    }
  </div>
</Base>
