---
import { SITE_DESCRIPTION, SITE_TITLE } from "src/config";
import LottieAnimation from "astro-integration-lottie/Lottie.astro";
import {
  LinkedInLogoIcon,
  DiscordLogoIcon,
  GitHubLogoIcon,
  EnvelopeClosedIcon,
} from "@radix-ui/react-icons";
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
---

<Layout head={{ title: SITE_TITLE, description: SITE_DESCRIPTION }} class="">
  <div class="bg-neutral-900 text-white">
    <div class="grid grid-cols-1 md:grid-cols-2">
      <div class="flex flex-col justify-center items-center">
        <div class="px-24 mt-10 sm:mt-0">
          <div class="w-64 h-64">
            <LottieAnimation
              src="https://lottie.host/d5fc664d-8b13-4731-b996-daa5aecb9baa/iQ2qJ5YLz7.json"
              autoplay="visible"
            />
          </div>
        </div>
        <div class="my-4 text-center space-y-2">
          <h1 class="text-3xl">Soodit Kumar</h1>
          <h2 class="text-xl text-gray-400">Delhi, India.</h2>
          <div class="flex justify-center items-center space-x-4">
            <a
              aria-label="Linkedin"
              href="https://www.linkedin.com/in/soodit-kumar-864a0a1b0/"
            >
              <LinkedInLogoIcon
                className="w-6 h-6 cursor-pointer text-gray-400"
              />
            </a>
            <a href="https://github.com/SooditK" aria-label="Github">
              <GitHubLogoIcon
                className="w-6 h-6 cursor-pointer text-gray-400"
              />
            </a>
          </div>
        </div>
      </div>
      <div class="flex flex-col h-screen py-12 px-6 sm:px-0 sm:py-16 gap-y-10">
        <div class="flex flex-col gap-y-2">
          <h3 class="text-3xl">About</h3>
          <div class="text-gray-300">
            I own a computer and I use{" "}
            <Image
              src="https://upload.wikimedia.org/wikipedia/commons/thumb/9/9f/Vimlogo.svg/1200px-Vimlogo.svg.png"
              class="w-6 h-6 inline-block"
              width={24}
              height={24}
              alt="vim"
            />{" "}
            and
            <Image
              src="https://upload.wikimedia.org/wikipedia/commons/thumb/7/73/Archlinux-logo-inverted-version.png/250px-Archlinux-logo-inverted-version.png"
              class="w-auto h-6 inline-block"
              width={100}
              height={100}
              alt="arch"
            />
          </div>
        </div>

        <div class="flex flex-col gap-y-2">
          <h3 class="text-3xl">Experience</h3>
          <p class="text-gray-300">
            I&apos;m breaking stuff at{" "}
            <a href="https://orennow.com" target="_blank" rel="noreferrer">
              <Image
                src="https://i.imgur.com/hz22k8P.png"
                class="w-auto h-10 inline-block"
                width={100}
                height={100}
                alt="Oren Logo"
              />
            </a>
          </p>
        </div>

        <div class="flex flex-col space-y-2">
          <h3 class="text-3xl">Skills</h3>
          <div class="text-gray-300">
            Quite Skillfull <br />
            <div class="space-x-2 mt-3">
              <Image
                src="https://upload.wikimedia.org/wikipedia/commons/thumb/f/f5/Typescript.svg/64px-Typescript.svg.png"
                class="w-6 h-6 inline-block"
                width={100}
                height={100}
                alt="Typescript"
              />
              <Image
                src="https://logos-download.com/wp-content/uploads/2019/01/JavaScript_Logo-700x700.png"
                class="w-6 h-6 inline-block"
                width={100}
                height={100}
                alt="Javascript"
              />
              <Image
                src="https://upload.wikimedia.org/wikipedia/commons/thumb/0/05/Go_Logo_Blue.svg/215px-Go_Logo_Blue.svg.png"
                class="w-auto h-4 inline-block"
                width={100}
                height={100}
                alt="Golang"
              />
              <Image
                src="https://www.rustacean.net/assets/rustacean-orig-noshadow.svg"
                class="w-auto h-6 inline-block"
                width={100}
                height={100}
                alt="Rust"
              />
              <Image
                src="https://upload.wikimedia.org/wikipedia/commons/thumb/d/d5/Tailwind_CSS_Logo.svg/512px-Tailwind_CSS_Logo.svg.png?20230715030042"
                class="w-auto h-5 inline-block"
                width={100}
                height={100}
                alt="TailwindCSS"
              />
              <Image
                src="https://upload.wikimedia.org/wikipedia/commons/thumb/a/a7/React-icon.svg/640px-React-icon.svg.png"
                class="w-auto h-5 inline-block"
                width={100}
                height={100}
                alt="React"
              />
              <Image
                src="https://upload.wikimedia.org/wikipedia/commons/thumb/1/18/ISO_C%2B%2B_Logo.svg/640px-ISO_C%2B%2B_Logo.svg.png"
                class="w-auto h-6 inline-block"
                width={100}
                height={100}
                alt="C++"
              />
              <Image
                src="https://yt3.ggpht.com/a/AATXAJzYT1rumwOdi0mza2hb91s3-7nQVtUSVDEBXQ=s900-c-k-c0xffffffff-no-rj-mo"
                class="w-auto h-6 inline-block"
                width={100}
                height={100}
                alt="OpenAI"
              />
              <span class="text-xl">🦜️🔗</span>
              <Image
                src="https://upload.wikimedia.org/wikipedia/commons/thumb/2/29/Postgresql_elephant.svg/640px-Postgresql_elephant.svg.png"
                class="w-auto h-6 inline-block"
                width={100}
                height={100}
                alt="Postgres"
              />
              <Image
                src="https://cdn.freebiesupply.com/logos/large/2x/nodejs-icon-logo-png-transparent.png"
                class="w-auto h-6 inline-block"
                width={100}
                height={100}
                alt="NodeJS"
              />
              <Image
                src="https://upload.wikimedia.org/wikipedia/commons/thumb/3/3c/TuxFlat.svg/640px-TuxFlat.svg.png"
                class="w-auto h-6 inline-block"
                width={100}
                height={100}
                alt="GNULINUX"
              />
            </div>
          </div>
        </div>

        <div class="flex flex-col gap-y-2">
          <h3 class="text-3xl">Here are some cat pics</h3>
          <div class="text-gray-300">
            <a href="/coolcat.webp" rel="noreferrer" target="_blank">
              cool cat
            </a>
            <br />
            <a href="/sleep.webp" rel="noreferrer" target="_blank">
              sleep cat
            </a>
            <br />
            <a href="/computercat.webp" rel="noreferrer" target="_blank">
              computer cat
            </a>
            <br />
            <a href="/angrycat.webp" rel="noreferrer" target="_blank">
              angry cat
            </a>
            <br />
            <a href="/catsanddogs.webp" rel="noreferrer" target="_blank">
              🐈🐕
            </a>
          </div>
        </div>

        <div class="flex flex-col gap-y-2">
          <h3 class="text-3xl">Contact</h3>
          <div class="text-gray-400">
            <a
              href="mailto:sooditkumar@duck.com"
              rel="noreferrer"
              target="_blank"
            >
              <EnvelopeClosedIcon className="w-auto h-4 inline-block mr-2" />
              sooditkumar@duck.com
            </a>
            <br />
            <div>
              <DiscordLogoIcon className="w-auto h-4 inline-block mr-2" />
              BabaYaga#9695
            </div>
          </div>
        </div>
        <div class="flex flex-col gap-y-2">
          <a href="/blog" class="text-3xl">
            <h3>Blogs</h3>
          </a>
        </div>
      </div>
    </div>
  </div>
</Layout>
